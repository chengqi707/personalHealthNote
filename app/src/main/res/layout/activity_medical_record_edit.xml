<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- 顶部导航栏 -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:theme="@style/Theme.PersonalHealthNote.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:popupTheme="@style/Theme.PersonalHealthNote.PopupOverlay"
            app:navigationIcon="?attr/homeAsUpIndicator" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- 表单区（可滚动） -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- 就医时间 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="就医时间 *"
                android:textColor="#333333"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvMedicalTime"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:hint="请选择就医时间"
                android:textSize="15sp"
                android:textColor="#333333"
                android:textColorHint="#999999"
                android:background="@drawable/bg_edit_text"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true" />

            <!-- 就诊医院 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="就诊医院 *"
                android:textColor="#333333"
                android:textSize="14sp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etHospital"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="请输入就诊医院名称"
                android:textSize="15sp"
                android:background="@drawable/bg_edit_text"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:inputType="text"
                android:maxLines="1" />

            <!-- 接诊医生 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="接诊医生"
                android:textColor="#333333"
                android:textSize="14sp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDoctor"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="请输入医生姓名+科室，如 张三 内科"
                android:textSize="15sp"
                android:background="@drawable/bg_edit_text"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:inputType="text"
                android:maxLines="1" />

            <!-- 症状描述 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="症状描述 *"
                android:textColor="#333333"
                android:textSize="14sp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSymptoms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:hint="请描述就诊时的症状，如：发烧、咳嗽、头晕"
                android:textSize="15sp"
                android:background="@drawable/bg_edit_text"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:inputType="textMultiLine"
                android:maxLines="3"
                android:maxLength="500"
                android:gravity="top|start"
                android:lineSpacingMultiplier="1.2" />

            <!-- 就诊结果 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="就诊结果 *"
                android:textColor="#333333"
                android:textSize="14sp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDiagnosisResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:hint="请输入就诊结论，如：感冒、支气管炎，医生建议..."
                android:textSize="15sp"
                android:background="@drawable/bg_edit_text"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:inputType="textMultiLine"
                android:maxLines="3"
                android:maxLength="500"
                android:gravity="top|start"
                android:lineSpacingMultiplier="1.2" />

            <!-- 检查项目 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="检查项目"
                android:textColor="#333333"
                android:textSize="14sp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCheckItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:hint="请输入检查项目，如：血常规、胸片、心电图，用逗号分隔"
                android:textSize="15sp"
                android:background="@drawable/bg_edit_text"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:inputType="textMultiLine"
                android:maxLines="3"
                android:maxLength="300"
                android:gravity="top|start"
                android:lineSpacingMultiplier="1.2" />

            <!-- 药品清单 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="药品清单"
                android:textColor="#333333"
                android:textSize="14sp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMedicines"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:hint="请输入药品名称及用法，如：布洛芬 每日3次，每次1片"
                android:textSize="15sp"
                android:background="@drawable/bg_edit_text"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:inputType="textMultiLine"
                android:maxLines="3"
                android:maxLength="300"
                android:gravity="top|start"
                android:lineSpacingMultiplier="1.2" />

        </LinearLayout>

    </ScrollView>

    <!-- 底部保存按钮 -->
    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="20dp"
        android:text="保存修改"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:background="@drawable/bg_button_primary"
        android:stateListAnimator="@null" />

</LinearLayout>
