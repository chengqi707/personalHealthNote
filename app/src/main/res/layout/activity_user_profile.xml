<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:theme="@style/Theme.PersonalHealthNote.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:popupTheme="@style/Theme.PersonalHealthNote.PopupOverlay" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 提示信息 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="填写基础信息后，AI评估将结合您的个人情况给出更精准的建议"
                android:textColor="@color/textSecondary"
                android:textSize="13sp"
                android:layout_marginBottom="16dp" />

            <!-- 基本信息 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="基本信息"
                android:textColor="@color/textSecondary"
                android:textSize="13sp"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- 性别 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="性别"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp" />

                    <Spinner
                        android:id="@+id/spinnerGender"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="4dp"
                        android:entries="@array/gender_options" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/divider" />

                    <!-- 出生日期 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="出生日期"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvBirthDate"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical"
                        android:text="请选择出生日期"
                        android:textColor="@color/textHint"
                        android:textSize="15sp"
                        android:background="@drawable/bg_edit_text"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/divider" />

                    <!-- 身高 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="身高 (cm)"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etHeight"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="4dp"
                        android:inputType="numberDecimal"
                        android:hint="请输入身高"
                        android:textColorHint="@color/textHint"
                        android:textSize="15sp"
                        android:background="@drawable/bg_edit_text"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/divider" />

                    <!-- 基线体重 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="基线体重 (kg)"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etWeight"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="4dp"
                        android:inputType="numberDecimal"
                        android:hint="请输入体重"
                        android:textColorHint="@color/textHint"
                        android:textSize="15sp"
                        android:background="@drawable/bg_edit_text"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- 健康信息 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="健康信息"
                android:textColor="@color/textSecondary"
                android:textSize="13sp"
                android:layout_marginStart="4dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- 过敏史 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="过敏史"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etAllergies"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:minHeight="60dp"
                        android:gravity="top"
                        android:inputType="textMultiLine"
                        android:hint="如：青霉素过敏、花粉过敏等"
                        android:textColorHint="@color/textHint"
                        android:textSize="15sp"
                        android:background="@drawable/bg_edit_text"
                        android:padding="12dp"
                        android:maxLength="200" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/divider" />

                    <!-- 慢性病 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="慢性病"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etChronicDiseases"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:minHeight="60dp"
                        android:gravity="top"
                        android:inputType="textMultiLine"
                        android:hint="如：高血压、糖尿病等"
                        android:textColorHint="@color/textHint"
                        android:textSize="15sp"
                        android:background="@drawable/bg_edit_text"
                        android:padding="12dp"
                        android:maxLength="200" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/divider" />

                    <!-- 家族病史 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="家族病史"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etFamilyHistory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:minHeight="60dp"
                        android:gravity="top"
                        android:inputType="textMultiLine"
                        android:hint="如：父亲冠心病、母亲糖尿病等"
                        android:textColorHint="@color/textHint"
                        android:textSize="15sp"
                        android:background="@drawable/bg_edit_text"
                        android:padding="12dp"
                        android:maxLength="200" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- 保存按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="24dp"
                android:text="保存"
                android:textSize="16sp"
                app:cornerRadius="24dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
