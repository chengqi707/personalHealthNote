<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.PersonalHealthNote" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- 主题色配置 -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primaryVariant</item>
        <item name="colorOnPrimary">@color/onPrimary</item>
        <!-- 状态栏配置 -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLightStatusBar">true</item>
        <!-- 导航栏配置 -->
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.PersonalHealthNote" parent="Base.Theme.PersonalHealthNote" />

    <!-- AppBarOverlay主题 -->
    <style name="Theme.PersonalHealthNote.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <!-- PopupOverlay主题 -->
    <style name="Theme.PersonalHealthNote.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <!-- 全屏主题（图片预览等） -->
    <style name="Theme.PersonalHealthNote.FullScreen" parent="Theme.PersonalHealthNote">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>