<?xml version="1.0" encoding="utf-8"?>
<!-- Data extraction rules for Android 12+ (API 31+).
     <cloud-backup>: Google Drive cloud backup (25MB limit - images may exceed).
     <device-transfer>: Device-to-device transfer for phone migration (no size limit).
     No include/exclude rules in either section = default = all app data included.
     This ensures phone clone/migration tools transfer: SQLite database, images in
     app_medical_records/ and app_records/ directories, shared preferences, etc. -->
<data-extraction-rules>
    <cloud-backup>
    </cloud-backup>
    <device-transfer>
    </device-transfer>
</data-extraction-rules>
